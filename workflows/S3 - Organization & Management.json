        "jsCode": "const output = $json.output || '';\n\nconst requiredKeywords = [\n    ['Management Team', 'Équipe de direction'],\n    ['Structure', 'Structure organisationnelle'],\n    ['Governance', 'Gouvernance'],\n    ['Legal', 'Juridique'],\n];\n\nconst missingKeywords = requiredKeywords.filter(group =>\n    !group.some(kw => output.toLowerCase().includes(kw.toLowerCase()))\n);\n\nreturn [{\n    json: {\n        ...$json,\n        keywords_valid: missingKeywords.length === 0 ? 'true' : 'false',\n        missing_keywords: missingKeywords.map(g => g[0]),\n    }\n}];"
