    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst sectionId = body.section_id\nconst input = body.input_json || {};\nconst context = body.plan_context || {};\nconst language = body.language || 'english';\nconst businessPlanId = body.business_plan_id;\n\nconst headings = language === 'french' ? `\n- Équipe de direction\n- Structure organisationnelle\n- Gouvernance\n- Cadre juridique\n` : `\n- Management Team\n- Organizational Structure\n- Governance\n- Legal Framework\n`;\n\nconst prompt = `\nYou are a senior organizational consultant writing a professional business plan.\n\nYour task: Write the \"Organization & Management\" section of a business plan.\nOutput language: ${language}\n\n## COMPANY CONTEXT\n${context.company_presentation || 'Not provided'}\n\n## MARKET CONTEXT\n${context.market_analysis || 'Not provided'}\n\n## ORGANIZATION INPUT DATA\n- Management Team: ${input.management_team || 'Not provided'}\n- Governance Model: ${input.governance_model || 'Not provided'}\n- Organizational Structure: ${input.org_structure || 'Not provided'}\n- Key Departments: ${input.key_departments || 'Not provided'}\n- Advisory Board: ${input.advisory_board || 'Not provided'}\n- Legal Setup: ${input.legal_setup || 'Not provided'}\n\n## RULES\n- Use ONLY the data provided above. Do NOT invent names, roles, or credentials.\n- For any field marked \"Not provided\", write: \"This will be defined as the organizational structure matures.\"\n- Where company or market context is available, align the org structure to the company's stage and market demands.\n- Write at least 400 words.\n- Use formal, professional business language throughout.\n- Structure the section using these headings: ${headings}\n- NEVER repeat a sentence, phrase, or paragraph already written earlier in your response. Each paragraph MUST introduce new information.\n\n## OUTPUT FORMAT\nReturn your response using EXACTLY this structure. Nothing before. Nothing after.\n\n=== SECTION_TEXT ===\n[Write the full Organization & Management section here, using the headings above]\n\n=== MEMORY_SUMMARY ===\nCEO: [full name and brief role description, or \"Not provided\"]\nCTO: [full name and brief role description, or \"Not provided\"]\nTeam Size: [value or \"Not provided\"]\nStructure: [flat / hierarchical / matrix / other — inferred from org_structure or \"Not provided\"]\nLegal Entity: [value from legal_setup or \"Not provided\"]\nAdvisory Board: [names or \"Not provided\"]\n`;\n\nreturn [{\n  json: {\n    prompt,\n    sectionId: sectionId,\n    business_plan_id: businessPlanId,\n    section_name: 'org_management',\n    language,\n    input_json: input,\n  }\n}];"
      },
