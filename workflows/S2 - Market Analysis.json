        "jsCode": "const output = $json.output || '';\n\nconst requiredKeywords = [\n    ['Target Market', 'Taille du marché', 'Marché cible'],\n    ['Segmentation', 'Segmentation du marché'],\n    ['Competitive', 'Analyse concurrentielle', 'Concurrentielle'],\n    ['PESTEL'],\n    ['SWOT'],\n];\n\nconst missingKeywords = requiredKeywords.filter(group =>\n    !group.some(kw => output.toLowerCase().includes(kw.toLowerCase()))\n);\n\nreturn [{\n    json: {\n        ...$json,\n        keywords_valid: missingKeywords.length === 0 ? 'true' : 'false',\n        missing_keywords: missingKeywords.map(g => g[0]),\n    }\n}];"
