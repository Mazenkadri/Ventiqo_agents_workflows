        "jsCode": "const output = $json.output || '';\n\nconst requiredKeywords = [\n    ['Company Overview', 'Présentation de l\\'entreprise', 'Aperçu'],\n    ['Mission'],\n    ['Vision'],\n    ['Founders', 'Fondateurs'],\n    ['Products', 'Produits', 'Services'],\n];\n\nconst missingKeywords = requiredKeywords.filter(group =>\n    !group.some(kw => output.toLowerCase().includes(kw.toLowerCase()))\n);\n\nreturn [{\n    json: {\n        ...$json,\n        keywords_valid: missingKeywords.length === 0 ? 'true' : 'false',\n        missing_keywords: missingKeywords.map(g => g[0]),\n    }\n}];"
