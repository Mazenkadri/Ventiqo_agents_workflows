    {
      "parameters": {
        "jsCode": "const raw = $('AI S1 Company').item.json.output || '';\n\n// Try strict format first\nlet textMatch = raw.match(/=== SECTION_TEXT ===([\\s\\S]*?)=== MEMORY_SUMMARY ===/);\nlet memMatch  = raw.match(/=== MEMORY_SUMMARY ===([\\s\\S]*?)$/);\n\n// Fallback: if model used wrong delimiter, try to split on any === ... === pattern\nif (!textMatch) {\n  const parts = raw.split(/===\\s*MEMORY_SUMMARY\\s*===/i);\n  textMatch = parts.length > 1 ? [null, parts[0].replace(/===.*?===/i, '').trim()] : null;\n  // Clean any wrong header like \"=== Company Presentation ===\" from the top\n}\n\nif (!memMatch) {\n  const parts = raw.split(/===\\s*MEMORY_SUMMARY\\s*===/i);\n  memMatch = parts.length > 1 ? [null, parts[1].trim()] : null;\n}\n\n// Strip any stray === ... === header from the section text\nlet section_text   = textMatch \n  ? textMatch[1].replace(/^===.*?===\\n?/i, '').trim() \n  : raw.trim();\nsection_text = section_text.replace(/===\\s*[^=]*?\\s*===/g, '').trim();\nconst memory_summary = memMatch ? memMatch[1].trim() : '';\n\n// Token estimation\nconst systemMsg = `You are a professional business plan writer. You MUST respond using EXACTLY this structure...`;\nconst promptText    = $('Build Prompt S1').item.json.prompt || '';\nconst isArabic      = /[\\u0600-\\u06FF]/.test(raw);\nconst charsPerToken = isArabic ? 3 : 4;\n\nconst tokens_input  = Math.round((systemMsg.length + promptText.length) / charsPerToken);\nconst tokens_output = Math.round(raw.length / charsPerToken);\nconst tokens_total  = tokens_input + tokens_output;\n\nconst buildData = $('Build Prompt S1').item.json;\n\nreturn [{\n  json: {\n    ...buildData,\n    output: section_text,\n    memory_summary,\n    tokens_input,\n    tokens_output,\n    tokens_total,\n  }\n}];"
      },
