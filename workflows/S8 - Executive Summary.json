    {
      "parameters": {
        "jsCode": "const body = $json.body || $json;\nconst sectionId = body.section_id;\nconst context = body.plan_context || {};\nconst language = body.language || 'english';\nconst businessPlanId = body.business_plan_id;\n\nconst headings = language === 'french' ? `\n- Aperçu de l'entreprise\n- Opportunité de marché\n- Notre solution\n- Équipe et leadership\n` : `\n- Business Overview\n- Market Opportunity\n- Our Solution\n- Team & Leadership\n`;\n\nconst prompt = `\nYou are writing a professional business plan section: Executive Summary.\nLanguage: ${language}\n\nBased on the following completed business plan sections, write a compelling Executive Summary:\n\n## Company Presentation\n${context.company_presentation || 'Not provided'}\n\n## Market Analysis\n${context.market_analysis || 'Not provided'}\n\n## Organization & Management\n${context.org_management || 'Not provided'}\n\n## Strategy\n${context.strategy || 'Not provided'}\n\n## Operational Plan\n${context.operational_plan || 'Not provided'}\n\n## Financial Plan\n${context.financial_plan || 'Not provided'}\n\n## Risk & Opportunity\n${context.risk_opportunity || 'Not provided'}\n\n## Appendices\n${context.appendices || 'Not provided'}\n\nWrite a compelling Executive Summary. Include these headings: ${headings}\n\nRules:\n- Minimum 400 words\n- This should be a concise summary of the entire business plan\n- Write in ${language}\n`;\n\nreturn [{\n  json: {\n    prompt,\n    sectionId: sectionId,\n    business_plan_id: businessPlanId,\n    section_name: 'executive_summary',\n    language,\n  }\n}];"
      },
