    {
      "parameters": {
        "jsCode": "const raw = $('AI Agent').item.json.output || '';\n\n// Remove MEMORY_SUMMARY block from display text\nconst textMatch = raw.match(/=== SECTION_TEXT ===([\\s\\S]*?)=== MEMORY_SUMMARY ===/);\nconst memMatch  = raw.match(/=== MEMORY_SUMMARY ===([\\s\\S]*?)$/);\n\nlet section_text = textMatch \n    ? textMatch[1].trim() \n    : raw.replace(/=== MEMORY_SUMMARY ===([\\s\\S]*?)$/, '').trim();\n\n// Also strip any stray === headings === from section text\nsection_text = section_text.replace(/===\\s*.*?\\s*===/g, '').trim();\n\nconst memory_summary = memMatch ? memMatch[1].trim() : '';\n\nconst promptText    = $('Build Prompt').item.json.prompt || '';\nconst tokens_input  = Math.round(promptText.length / 4);\nconst tokens_output = Math.round(raw.length / 4);\nconst tokens_total  = tokens_input + tokens_output;\n\nconst buildData = $('Build Prompt').item.json;\nreturn [{\n    json: {\n        ...buildData,\n        output: section_text,\n        memory_summary: null,\n        tokens_input,\n        tokens_output,\n        tokens_total,\n    }\n}];"
      },
